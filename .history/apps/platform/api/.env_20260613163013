# =============================================================================
# 后端 API 运行时配置（本文件被 dev.mjs / nest 实际加载）
# 模板见项目根目录 .env.example；修改后需重启 API。
# =============================================================================

# ── App ──
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
API_BASE_URL=http://localhost:3000

# ── Database ──
# 本地开发（Docker PostgreSQL：pnpm docker:up）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wm_platform?schema=public

# ── Redis / BullMQ ──
REDIS_URL=redis://localhost:6379

# ── Auth (Logto / Supabase — 后期接入) ──
AUTH_ISSUER=
AUTH_AUDIENCE=

# ── Network proxy（PackyAPI/Serper 建议走 Clash；API 已将连接超时从 10s 提到 60s 并自动重试）──
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
HTTP_CONNECT_TIMEOUT_MS=60000
HTTP_FETCH_RETRY_MAX=3
HTTP_FETCH_RETRY_DELAY_MS=2000
NO_PROXY=localhost,127.0.0.1


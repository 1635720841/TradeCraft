# ── App ──
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
API_BASE_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wm_platform?schema=public

# ── Redis / BullMQ ──
REDIS_URL=redis://localhost:6379

# ── Auth (Logto / Supabase — 后期接入) ──
AUTH_ISSUER=
AUTH_AUDIENCE=

# ── Network proxy（Node fetch 不走系统代理；国内开发访问 Serper/DeepSeek 时启用）──
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NODE_USE_ENV_PROXY=1

# ── Providers (seo-factory) ──
PROVIDER_LLM=deepseek
PROVIDER_SERP=serper
PROVIDER_IMAGE=flux
DEEPSEEK_API_KEY=
SERPER_API_KEY=
FLUX_API_KEY=

# Semrush RPA（3ue 共享号，本地 SEO ≥80 分后触发）
SEMRUSH_ENABLED=false
SEMRUSH_3UE_USERNAME=
SEMRUSH_3UE_PASSWORD=
# 调试时可设 false 显示浏览器窗口
SEMRUSH_HEADLESS=true

# ── Storage ──
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# 后端 API 环境变量模板（复制为 apps/platform/api/.env 并填写）
# 完整字段说明见仓库根目录 .env.example
# =============================================================================

# ── App ──
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
WEB_APP_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wm_platform?schema=public

# ── Redis / BullMQ ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
AUTH_JWT_SECRET=change-me-min-16-chars
# 敏感凭证加密密钥（GSC 等）；生产环境建议与 AUTH_JWT_SECRET 分离
SECRET_CIPHER_KEY=
AUTH_ISSUER=
AUTH_AUDIENCE=

# ── Google Search Console（可选）──
GOOGLE_GSC_CLIENT_ID=
GOOGLE_GSC_CLIENT_SECRET=
GOOGLE_GSC_REDIRECT_URI=
GOOGLE_GSC_STATE_SECRET=

# ── LLM（OpenAI 兼容）──
PROVIDER_LLM=deepseek
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_MODEL=

# ── Object Storage（可选）──
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── GSC 定时同步（可选）──
GSC_AUTO_SYNC_ENABLED=false

# ── 自动生产定时调度（可选）──
AUTOPILOT_SCHEDULER_ENABLED=false

# ── 演示插件（开发/排障，默认关闭）──
DEMO_FACTORY_ENABLED=false

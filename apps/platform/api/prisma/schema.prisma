// SaaS 平台统一 Schema：平台表 + seo-factory 业务表

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 平台层 ──

enum OrganizationType {
  CUSTOMER
  PLATFORM
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model Organization {
  id                   String             @id @default(uuid())
  type                 OrganizationType   @default(CUSTOMER)
  status               OrganizationStatus @default(ACTIVE)
  name                 String
  planId               String?
  plan                 SubscriptionPlan?  @relation(fields: [planId], references: [id])
  planName             String             @default("trial")
  monthlyArticleQuota  Int                @default(100)
  articleQuotaBonus    Int                @default(0)
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  billingCycle         BillingCycle       @default(MONTHLY)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  users                User[]
  projects             Project[]
  usageLogs            CreditUsage[]
  auditLogs            AuditLog[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([type, status])
}

model SubscriptionPlan {
  id                  String         @id /// trial | standard | enterprise
  name                String
  monthlyArticleQuota Int
  billingCycle        BillingCycle   @default(MONTHLY)
  isActive            Boolean        @default(true)
  sortOrder           Int            @default(0)
  organizations       Organization[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

/// 平台权限目录
model Permission {
  id          String           @id /// 如 org:member:list
  name        String
  module      String
  description String?          @db.VarChar(200)
  sortOrder   Int              @default(0)
  grants      UserPermission[]
  createdAt   DateTime         @default(now())

  @@index([module, sortOrder])
}

/// 用户额外授权（在角色默认权限之上叠加）
model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedById  String?
  createdAt    DateTime   @default(now())

  @@unique([userId, permissionId])
  @@index([userId])
}

/// 侧栏菜单目录
model PlatformMenu {
  id           String          @id /// 如 org:members
  title        String
  routePath    String
  permissionId String?
  targetRoles  String[]
  sortOrder    Int             @default(0)
  grants       RoleMenuGrant[]
  userGrants   UserMenuGrant[]
  createdAt    DateTime        @default(now())

  @@index([sortOrder])
}

/// 角色菜单可见策略
model RoleMenuGrant {
  id        String       @id @default(uuid())
  role      Role
  menuId    String
  menu      PlatformMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  enabled   Boolean      @default(true)
  updatedAt DateTime     @updatedAt

  @@unique([role, menuId])
  @@index([role, enabled])
}

/// 用户菜单可见策略（超管按账号配置侧栏）
model UserMenuGrant {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuId      String
  menu        PlatformMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  enabled     Boolean      @default(true)
  grantedById String?
  updatedAt   DateTime     @updatedAt

  @@unique([userId, menuId])
  @@index([userId, enabled])
}

/// 操作审计
model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUserId    String
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  traceId        String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingRequestType {
  RENEW
  UPGRADE
  TOPUP
}

enum BillingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// 成员邮件邀请
model MemberInvite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           Role      @default(MEMBER)
  tokenHash      String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@unique([organizationId, email])
  @@index([tokenHash])
  @@index([organizationId, createdAt])
}

/// 项目访问申请
model ProjectAccessRequest {
  id             String              @id @default(uuid())
  organizationId String
  projectId      String
  userId         String
  message        String?             @db.VarChar(500)
  status         AccessRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())

  @@index([organizationId, projectId, status])
  @@index([organizationId, status, createdAt])
}

/// 站内通知
model UserNotification {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  type           String
  title          String
  body           String?   @db.VarChar(500)
  linkPath       String?   @db.VarChar(500)
  readAt         DateTime?
  payload        Json?
  createdAt      DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([organizationId, userId, createdAt])
}

/// 续费/升级申请
model BillingChangeRequest {
  id             String               @id @default(uuid())
  organizationId String
  requestedById  String
  type           BillingRequestType
  targetPlanId   String?
  topUpAmount    Int?
  message        String?              @db.VarChar(500)
  status         BillingRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())

  @@index([organizationId, status, createdAt])
  @@index([status, createdAt])
}

/// 出站 Webhook 配置
model OrgWebhook {
  id             String   @id @default(uuid())
  organizationId String
  url            String   @db.VarChar(500)
  secret         String
  events         String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isActive])
}

/// Webhook 投递日志
model WebhookDeliveryLog {
  id             String   @id @default(uuid())
  organizationId String
  webhookId      String
  event          String
  statusCode     Int?
  success        Boolean
  errorMessage   String?  @db.VarChar(500)
  createdAt      DateTime @default(now())

  @@index([organizationId, webhookId, createdAt])
}

/// 钉钉/飞书机器人通知通道
model OrgRobotChannel {
  id             String   @id @default(uuid())
  organizationId String
  channelType    String   /// dingtalk | feishu
  webhookUrl     String   @db.VarChar(500)
  isActive       Boolean  @default(true)
  events         String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isActive])
}

/// 用户通知偏好（按企业）
model UserNotificationPreference {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  emailEnabled   Boolean  @default(true)
  mutedTypes     String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, userId])
}

/// Prompt 模板版本库（M12）：平台全局，seo-factory LLM 热更新
model PromptTemplate {
  id          String   @id @default(uuid())
  version     String   @unique /// 如 seo_brief_v1，与 briefData.promptVersion 对齐
  name        String
  description String?  @db.Text
  content     String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([updatedAt])
}

/// 功能槽位 → Prompt 版本绑定（运营可在后台切换）
model PromptRuntimeBinding {
  slotId        String   @id /// brief | draft | localOptimize | semrushOptimize | rewrite
  activeVersion String
  updatedAt     DateTime @updatedAt
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String?
  passwordHash   String? /// 开发/自建 Auth；Logto 接入后可空
  authSubject    String?          @unique /// 外部 IdP sub（Logto/Supabase）
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  role           Role             @default(MEMBER)
  status         UserStatus       @default(ACTIVE)
  locale         String           @default("zh-CN")
  lastLoginAt    DateTime?
  grants         UserPermission[]
  menuGrants     UserMenuGrant[]
  projectMembers ProjectMember[]
  createdAt      DateTime         @default(now())

  @@index([organizationId])
  @@index([organizationId, status])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  name            String
  projectType     String // 'seo-factory' | future types
  config          Json?
  status          ProjectStatus    @default(ACTIVE)
  accessStart     DateTime?
  accessEnd       DateTime?
  sites           Site[]
  jobs            ArticleJob[]
  keywords        KeywordEntry[]
  keywordClusters KeywordCluster[]
  members         ProjectMember[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}

/// 项目成员：按项目开放访问与权限
model ProjectMember {
  id          String                    @id @default(uuid())
  projectId   String
  project     Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        ProjectMemberRole         @default(VIEWER)
  accessStart DateTime?
  accessEnd   DateTime?
  grantedById String?
  permissions ProjectMemberPermission[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/// 项目成员额外权限（在角色默认之上叠加）
model ProjectMemberPermission {
  id           String        @id @default(uuid())
  memberId     String
  member       ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  permissionId String
  createdAt    DateTime      @default(now())

  @@unique([memberId, permissionId])
  @@index([memberId])
}

model CreditUsage {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  projectType    String?
  serviceType    String // SERP | LLM | IMAGE | RPA
  provider       String
  tokensOrCount  Int          @default(0)
  estimatedCost  Float        @default(0)
  traceId        String?
  breakdown      Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

enum Role {
  SUPER_ADMIN
  PLATFORM_OPERATOR
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

// ── seo-factory 业务表 ──

model Site {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  domain           String
  brandVoice       String?      @db.Text
  targetMarket     String?
  contentLanguage  String       @default("en")
  cmsType          String?      /// null | wordpress
  cmsConfig        Json?        /// WordPress: { baseUrl, username, applicationPassword, defaultStatus }
  settings         Json?        /// { requireBriefApproval?: boolean }
  jobs             ArticleJob[]
  pages            SitePage[]
  keywords         KeywordEntry[]
  gscConnection    SiteGscConnection?
  createdAt      DateTime     @default(now())

  @@index([organizationId, projectId])
}

/// 站点页面库：供 M8 内链匹配（同站点已索引页面）
model SitePage {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url            String
  title          String
  summary        String?      @db.Text
  keywords       String[]     @default([])
  primaryKeyword String?      /// 页面主关键词，供内链匹配加权
  pageType       SitePageType @default(PAGE)
  businessValue  Float        @default(0.5)
  lastUpdated    DateTime?
  source         String       @default("sitemap")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([siteId, url])
  @@index([organizationId, projectId, siteId])
}

enum SitePageType {
  PRODUCT
  SERVICE
  SOLUTION
  BLOG
  PAGE
}

enum ArticleContentForm {
  ARTICLE
  PRODUCT_ENHANCED
  FAQ_PAGE
}

model ArticleJob {
  id             String    @id @default(uuid())
  traceId        String    @unique
  organizationId String
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  siteId         String
  site           Site      @relation(fields: [siteId], references: [id])
  targetKeyword    String
  contentLanguage  String    @default("en")
  searchIntent     String?            /// KeywordIntent 快照：入队时写入，驱动 Brief/Draft Prompt
  contentForm      ArticleContentForm @default(ARTICLE)
  status           JobStatus          @default(QUEUED)
  briefData      Json?
  serpData       Json?
  draftData      Json?
  localSeoScore  Float?
  seoCheckData   Json?
  semrushScore   Float?
  outputUrl      String?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  comments       ArticleJobComment[]
  assignees      ArticleJobAssignee[]
  activities     ArticleJobActivity[]

  @@index([organizationId, projectId, status])
  @@index([organizationId, projectId, createdAt])
}

model ArticleJobComment {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  jobId          String
  job            ArticleJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorUserId   String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, projectId, jobId, createdAt])
}

model ArticleJobAssignee {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  jobId          String
  job            ArticleJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId         String
  assignedById   String?
  createdAt      DateTime @default(now())

  @@unique([jobId, userId])
  @@index([organizationId, projectId, userId])
}

model ArticleJobActivity {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  jobId          String
  job            ArticleJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type           String
  actorUserId    String
  summary        String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, projectId, jobId, createdAt])
}

enum JobStatus {
  QUEUED
  RESEARCHING
  DRAFTING
  LINKING
  ILLUSTRATING
  OPTIMIZING
  REVIEWING
  COMPLETED
  FAILED
}

enum KeywordIntent {
  INFORMATIONAL
  COMMERCIAL
  TRANSACTIONAL
  BRAND
  COMPETITOR
}

enum KeywordStatus {
  PENDING
  APPROVED
  ARCHIVED
  USED
}

enum KeywordSource {
  MANUAL
  IMPORT
  AI_SEED
}

/// 主题集群：将相关关键词分组，便于按主题排产与内链规划
model KeywordCluster {
  id             String         @id @default(uuid())
  organizationId String
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  description       String?        @db.Text
  pillarKeywordId   String?
  pillarKeyword     KeywordEntry?  @relation("ClusterPillar", fields: [pillarKeywordId], references: [id], onDelete: SetNull)
  keywords          KeywordEntry[] @relation("ClusterKeywords")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([projectId, name])
  @@index([organizationId, projectId])
  @@index([pillarKeywordId])
}

/// 项目关键词池：发现、优先级排序与任务入队
model KeywordEntry {
  id                  String          @id @default(uuid())
  organizationId      String
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id])
  siteId              String?
  site                Site?           @relation(fields: [siteId], references: [id])
  clusterId           String?
  cluster             KeywordCluster?  @relation("ClusterKeywords", fields: [clusterId], references: [id], onDelete: SetNull)
  pillarForClusters   KeywordCluster[] @relation("ClusterPillar")
  keyword             String
  intent              KeywordIntent  @default(INFORMATIONAL)
  status              KeywordStatus  @default(PENDING)
  source              KeywordSource  @default(MANUAL)
  searchVolume        Int?
  keywordDifficulty   Float?
  cpc                 Float?
  businessValueScore  Float          @default(0.5)
  contentFitScore     Float          @default(0.5)
  priorityScore       Float          @default(0)
  notes               String?        @db.Text
  lastJobId           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([projectId, keyword])
  @@index([organizationId, projectId, status])
  @@index([organizationId, projectId, priorityScore])
  @@index([organizationId, projectId, clusterId])
}

/// Google Search Console 站点授权与同步快照
model SiteGscConnection {
  id             String    @id @default(uuid())
  organizationId String
  siteId         String    @unique
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  propertyUrl    String?   /// sc-domain:example.com 或 https://example.com/
  refreshToken   String?   @db.Text
  lastSyncAt     DateTime?
  lastSyncError  String?   @db.Text
  summaryData    Json?     /// 最近一次同步的聚合指标（页面/查询 Top N）
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
}

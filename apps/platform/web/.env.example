# =============================================================================
# 前端 Vite 环境变量模板（复制为 apps/platform/web/.env 并填写）
# 后端密钥与数据库配置见仓库根目录 .env.example → apps/platform/api/.env
# =============================================================================
# 开发服务器端口
VITE_PORT=5173

# 公共路径（部署子路径时修改，默认 /）
VITE_PUBLIC_PATH=/

# 后端 API 地址（Vite 代理目标，开发时默认 http://localhost:3000）
VITE_API_BASE_URL=http://localhost:3000

# 路由模式：hash | history
VITE_ROUTER_HISTORY=hash

# 是否启用 CDN 加速构建产物
VITE_CDN=false

# 构建压缩：none | gzip | brotli | both
VITE_COMPRESSION=none

# 隐藏首页（true 时登录后直达项目首页）
VITE_HIDE_HOME=false

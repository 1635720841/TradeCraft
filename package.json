{
  "name": "wm",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "pnpm --filter @wm/platform-api dev",
    "dev:web": "pnpm --filter @wm/platform-web dev",
    "dev:kill-api": "node scripts/kill-port.mjs 3000",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:generate": "pnpm --filter @wm/platform-api db:generate",
    "db:migrate": "pnpm --filter @wm/platform-api db:migrate",
    "db:deploy": "pnpm --filter @wm/platform-api db:deploy",
    "test:seo": "pnpm --filter @wm/platform-api test:local-seo",
    "test:e2e": "pnpm --filter @wm/platform-api test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "es5-ext",
      "prisma",
      "typeit",
      "vue-demi"
    ]
  }
}

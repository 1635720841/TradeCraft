    │       └── project.routes.ts     # 项目路由（动态加载插件）
    ├── stores/
    │   ├── auth.store.ts
    │   ├── project.store.ts
    │   ├── locale.store.ts
    │   └── project-context.store.ts
    ├── api/
    │   ├── client.ts             # 统一 HTTP 客户端
    │   ├── project.api.ts
    │   └── seo-factory/
    │       └── article-job.api.ts
    ├── composables/
    │   ├── use-api-error.ts
    │   ├── use-pagination.ts
    │   └── seo-factory/
    ├── components/
    │   ├── common/               # 平台通用 UI 组件
    │   │   ├── AppLayout.vue
    │   │   ├── AppHeader.vue
    │   │   ├── AppSidebar.vue
    │   │   ├── AppPagination.vue
    │   │   └── LocaleSwitcher.vue
    │   └── seo-factory/          # SEO 插件专属组件
    ├── views/
    │   ├── platform/             # 平台页面
    │   │   ├── ProjectListView.vue
    │   │   ├── ProjectCreateView.vue
    │   │   ├── BillingView.vue
    │   │   └── SettingsView.vue

# =============================================================================
# 环境变量模板（提交 Git，不含真实密钥）
#
# 首次使用请复制到 API 目录：
#   cp .env.example apps/platform/api/.env
# 然后编辑 apps/platform/api/.env 填入真实 Key。
#
# 各 .env 文件职责：
#   .env.example              → 本文件，仅作模板/文档
#   apps/platform/api/.env    → 后端 API 实际读取（LLM、数据库、Semrush 等）
#   apps/platform/web/.env      → 前端 Vite 配置（端口、路由模式等）
#
# 注意：项目根目录不要放 .env，API 不会读取。
# =============================================================================

# ── App ──
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
API_BASE_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wm_platform?schema=public

# ── Redis / BullMQ ──
REDIS_URL=redis://localhost:6379

# ── Auth（JWT + 可选 Logto OIDC）──
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWT_SECRET=change-me-in-production-min-16-chars
# 本地密码登录（开发默认开启；生产接 Logto 后可设 false）
AUTH_ALLOW_LOCAL_LOGIN=true
# Logto（三者齐全时启用「使用 Logto 登录」；redirect 须与 Logto 控制台一致）
# LOGTO_ENDPOINT=https://your-tenant.logto.app
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=
# Hash 路由示例：http://localhost:5173/#/login/callback
# LOGTO_REDIRECT_URI=http://localhost:5173/#/login/callback

# ── Playwright 专用队列（Semrush RPA 低频限速，默认开启）──
PLAYWRIGHT_QUEUE_ENABLED=true
PLAYWRIGHT_QUEUE_CONCURRENCY=1
PLAYWRIGHT_QUEUE_RATE_LIMIT_MAX=1
PLAYWRIGHT_QUEUE_RATE_LIMIT_DURATION_MS=60000
PLAYWRIGHT_QUEUE_JOB_TIMEOUT_MS=180000

# ── 竞品页面抓取（SERP 有机结果正文，默认开启）──
SCRAPER_COMPETITOR_ENABLED=true
SCRAPER_COMPETITOR_CONCURRENCY=2
SCRAPER_COMPETITOR_TIMEOUT_MS=15000
SCRAPER_COMPETITOR_MAX_CHARS=8000
SCRAPER_COMPETITOR_MAX_HEADINGS=20

# ── Semrush 浏览器池（复用 Chromium，默认 1 实例）──
SEMRUSH_BROWSER_POOL_SIZE=1

# ── API 限流（按 organizationId，Redis 固定窗口）──
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ORG_MAX=120
RATE_LIMIT_ORG_WINDOW_SEC=60

# ── Network proxy（PackyAPI/Serper 经 Clash；连接超时默认 10s 易失败，已由 API 拉长）──
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# HTTP_CONNECT_TIMEOUT_MS=60000
# HTTP_FETCH_RETRY_MAX=3
# HTTP_FETCH_RETRY_DELAY_MS=2000
# 仅本地不走代理；PackyAPI 若直连易 Connect Timeout，不要加入 NO_PROXY
# NO_PROXY=localhost,127.0.0.1

# ── LLM（OpenAI 兼容，Brief/初稿/优化均走此处）──
# 预设：deepseek | openai | packyapi（LLM_* 可覆盖预设）
PROVIDER_LLM=deepseek
# 通用 Key（PackyAPI / OpenAI 等填这里）；未填时回退 DEEPSEEK_API_KEY
LLM_API_KEY=
# LLM_API_BASE_URL=https://www.packyapi.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_JSON_MODE=true
DEEPSEEK_API_KEY=

# ── 其他外部服务 ──
PROVIDER_SERP=serper
PROVIDER_IMAGE=bfl
SERPER_API_KEY=

# ── BFL 官方生图（Black Forest Labs）──
# Key：https://dashboard.bfl.ai
BFL_API_KEY=
# 端点 slug，见 https://docs.bfl.ml — 默认 flux-2-klein-4b（约 $0.014/张）
BFL_IMAGE_ENDPOINT=flux-2-klein-4b
# BFL_API_BASE_URL=https://api.bfl.ai

# ── Semrush RPA（3ue 共享号，本地 SEO ≥80 分后触发）──
SEMRUSH_ENABLED=false
SEMRUSH_3UE_USERNAME=
SEMRUSH_3UE_PASSWORD=
# 3ue 节点：数字/节点N/地区码（如 1、节点3、TW）；留空则从第一个 ✅ 在线节点开始试
SEMRUSH_3UE_NODE=1
SEMRUSH_NODE_ATTEMPT_TIMEOUT_MS=30000
SEMRUSH_CACHE_CLEAN_MAX_MS=12000
SEMRUSH_NODE_MAX_ATTEMPTS=5
SEMRUSH_BROWSER_CHANNEL=chrome
SEMRUSH_HEADLESS=true
# Semrush Analytics API（关键词池指标回填；未配置时使用开发估算 Stub）
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us

# ── QuillBot / 原创表达优化（Semrush 后 LLM 润色；设 true 可跳过）──
QUILLBOT_DISABLED=false

# ── Storage ──
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# 可选：MinIO / 兼容 S3 端点
S3_ENDPOINT=
